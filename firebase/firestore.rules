rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // PROFILES
    match /profiles/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // TRIPS
    match /trips/{tripId} {
      allow read, update: if request.auth != null;
      allow create:       if request.auth != null;
    }

    // TRIP MEMBERS
    match /trip_members/{memberId} {
      allow read, create, delete: if request.auth != null;
    }

    // ITINERARY EVENTS
    match /itinerary_events/{eventId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && resource.data.created_by == request.auth.uid;
    }

    // TRAVEL DETAILS
    match /travel_details/{detailId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
    }

    // POLLS
    match /polls/{pollId} {
      allow read, create: if request.auth != null;
      allow delete:       if request.auth != null
                          && resource.data.created_by == request.auth.uid;
    }

    // POLL OPTIONS
    match /poll_options/{optionId} {
      allow read, create: if request.auth != null;
    }

    // POLL VOTES
    match /poll_votes/{voteId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.user_id == request.auth.uid;
    }

    // PHOTO ALBUMS
    match /photo_albums/{albumId} {
      allow read, create: if request.auth != null;
      allow delete:       if request.auth != null
                          && resource.data.added_by == request.auth.uid;
    }

    // CALENDAR TOKENS
    // Tokens are created and read by their owner only.
    // The Cloud Function uses the Admin SDK which bypasses these rules entirely.
    match /calendar_tokens/{token} {
      allow read, delete: if request.auth != null
                          && resource.data.created_by == request.auth.uid;
      allow create:       if request.auth != null
                          && request.resource.data.created_by == request.auth.uid;
    }
  }
}
